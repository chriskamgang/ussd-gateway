<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1628"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="USSD Gateway"
            android:textColor="#00D4FF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MunaPay — Envoi automatique de crédit/forfaits"
            android:textColor="#8899AA"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Statut"
                android:textColor="#8899AA"
                android:textSize="13sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Non activé"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvProcessed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 tâche(s) traitée(s)"
                android:textColor="#8899AA"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvAccessibility"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accessibility: désactivé"
                android:textColor="#FF6B6B"
                android:textSize="13sp"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- Activation Section (shown when not activated) -->
        <LinearLayout
            android:id="@+id/layoutActivation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Activation"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Entrez le code d'activation pour connecter ce téléphone au serveur"
                android:textColor="#8899AA"
                android:textSize="13sp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/etCode"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/input_bg"
                android:textColor="#FFFFFF"
                android:textColorHint="#556677"
                android:hint="Code d'activation"
                android:textSize="18sp"
                android:textAlignment="center"
                android:letterSpacing="0.3"
                android:textStyle="bold"
                android:paddingHorizontal="16dp"
                android:inputType="text"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnActivate"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Activer"
                android:backgroundTint="#00D4FF"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Start/Stop Button (shown when activated) -->
        <Button
            android:id="@+id/btnToggle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Démarrer le service"
            android:backgroundTint="#00D4FF"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone"
            android:layout_marginBottom="12dp" />

        <!-- SIM Selection (shown when activated) -->
        <LinearLayout
            android:id="@+id/layoutSim"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Carte SIM Camtel"
                android:textColor="#8899AA"
                android:textSize="13sp"
                android:layout_marginBottom="8dp" />

            <RadioGroup
                android:id="@+id/rgSim"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbSim1"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="SIM 1"
                    android:textColor="#FFFFFF"
                    android:buttonTint="#00D4FF"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/rbSim2"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="SIM 2"
                    android:textColor="#FFFFFF"
                    android:buttonTint="#00D4FF" />

            </RadioGroup>
        </LinearLayout>

        <!-- Open Accessibility Settings -->
        <Button
            android:id="@+id/btnAccessibility"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Activer l'accessibilité"
            android:backgroundTint="#1A2A40"
            android:textColor="#FF9500"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Log -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Journal"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:textColor="#8899AA"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:text="En attente d'activation..."
            android:minHeight="150dp"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
